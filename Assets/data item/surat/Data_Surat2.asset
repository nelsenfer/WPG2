  icon: {fileID: 0}
  isKertasCatatan: 1
  isiKertas: "Ada yang terus memperhatikan dari balik celah.\nBukan untuk menakut-nakuti\u2026\ntapi
    karena <i>tidak pernah benar-benar dipahami.</i>\n\nIa terbiasa dilihat,\nnamun
    <b>tidak pernah benar-benar dilihat.</b>\n\nJika kau bertemu dengannya nanti,\njangan
    hanya menjawab\u2026\n<u>pahami apa yang tidak ia katakan.</u>"
