--- !u!114 &354009005
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 354009001}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cec32b56af96dcb439f95152a8772127, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  panelPilihan: {fileID: 2116896086}
  tombolPertama: {fileID: 1089943614}
  teksTombol1: {fileID: 505976863}
  teksTombol2: {fileID: 1672194538}
  spriteWorldKuchisake: {fileID: 354009004}
  pixelSeram: {fileID: -6332038312564588027, guid: ab62d17b400f74e4c9534cf625cb8a9a, type: 3}
  pixelCantik: {fileID: -8066049841729604535, guid: e7dca6d736131f540af8cab62cd13ca6, type: 3}
  potretTaku: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
  potretSeram: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
  potretCantik: {fileID: -1472521909002408458, guid: 9f2ee797f400b8747bdbb843f548586b, type: 3}
  naskahIntro:
  - namaKarakter: Kuchisake Onna
    isiTeks: Akhirnya aku bertemu denganmu, Tachibana Takumi.
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: Aku tidak berniat macam-macam padamu, aku hanya terjebak disini dan
      ingin keluar dari tempat ini.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Kuchisake Onna
    isiTeks: Jika kau bisa menjawab tiga pertanyaan dariku, maka pergilah sesuai
      arahan yang kuberikan.
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: Baiklah....
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Kuchisake Onna
    isiTeks: "Kalau semua orang hanya melihat penampilan\u2026 menurutmu\u2026 apakah
      aku masih punya arti?"
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  opsi1Lose:
  - namaKarakter: Taku
    isiTeks: Ya orang lihatnya gitu, mau gimana lagi.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  opsi1Win:
  - namaKarakter: Taku
    isiTeks: "Mungkin mereka cuma lihat dari luar\u2026 tapi itu bukan berarti kamu
      jadi tidak berharga."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  reaksi1:
  - namaKarakter: Kuchisake Onna
    isiTeks: "Jawaban yang cukup unik.... Lalu, kalau seseorang disakiti sampai berubah
      entah secara fisik atau mental\u2026 apa mereka juga harus disalahkan?"
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  opsi2Win:
  - namaKarakter: Taku
    isiTeks: "Orang nggak bakal berubah tanpa alasan\u2026 jadi bagiku, itu bukan
      sepenuhnya salah mereka."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  opsi2Lose:
  - namaKarakter: Taku
    isiTeks: Kalau sampai berubah gitu, itu kesalahan sendiri.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  reaksi2:
  - namaKarakter: Kuchisake Onna
    isiTeks: "Kalau kamu berada di posisiku\u2026 apa kamu masih bisa menerima dirimu
      sendiri setelah semua yang telah terjadi?"
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  opsi3Win:
  - namaKarakter: Taku
    isiTeks: "Kalau aku di posisimu\u2026 mungkin aku juga kesulitan\u2026 tapi aku
      tetap mau coba nerima, walau pelan-pelan."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  opsi3Lose:
  - namaKarakter: Taku
    isiTeks: Kalau nggak bisa nerima, ya masalahmu.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  reaksi3:
  - namaKarakter: Kuchisake Onna
    isiTeks: Kali ini aku membenci jawabanmu, keyakinanmu runtuh di pertanyaan ketiga.
      Sekarang pertanyaan terakhirku. Kamu melihatku sebagai apa?
    potretKarakter: {fileID: 3145934824342851086, guid: 10414e7f6aa62ae439a73cc6e3c78c8d, type: 3}
    potretDiKiri: 0
  opsi4Win:
  - namaKarakter: Taku
    isiTeks: "Aku nggak lihat kamu sebagai sesuatu yang menakutkan\u2026 aku lihat
      kamu sebagai seseorang yang terluka."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  opsi4Lose:
  - namaKarakter: Taku
    isiTeks: "Aku lihat kamu\u2026 cuma sebagai sesuatu yang harus dijauhi."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  naskahPenutup:
  - namaKarakter: 
    isiTeks: (Kuchisake Onna tanpa sadar mulai meneteskan air mata. Perlahan wajah
      menyeramkannya berubah menjadi sosok wanita cantik...)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: (Terdengar suara pintu berat di belakang terbuka dengan sendirinya...)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  - namaKarakter: Kuchisake Onna
    isiTeks: "\u2026terima kasih\u2026 karena sudah melihatku\u2026sebagai manusia."
    potretKarakter: {fileID: -1472521909002408458, guid: 9f2ee797f400b8747bdbb843f548586b, type: 3}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: (Ia tersenyum manis lalu menghilang ke udara. Di kejauhan, Yokai lain
      tampak mengawasimu dengan kehangatan.)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  titikJalanKeluar: {fileID: 1970343439}
  layarPutihTransisi: {fileID: 1100918354}
  namaSceneMainMenu: Epilog
  promptUI: {fileID: 0}
