  m_EditorClassIdentifier: 
  naskahChopirako:
  - namaKarakter: Taku
    isiTeks: eh adik kecil ngapain kamu disitu, turun turun.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: ihihihi, om lucu banget.
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: (eh om? Aku masih 25 tahun?)
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: kenalin aku Chopirako, aku boleh gk main sama om sebentar.
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: Ya apa? Mau main apa?
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: ihihihi, suka deh sama om, tapi aku Cuma mau boneka yang om bawa. Boleh
      gk aku ambil? Itu bonekanya bagus banget.
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: nih ambil aja, suka banget ya?
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: iya kayak mirip boneka yang pernah dikasih orang tuaku dulu.
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: oohh... hmm okelah kalo kamu seneng. Om lanjut dulu ya.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: 'eh tunggu!!

      hehehe kata orang tuaku kalo berbuat baik harus
      ada timbal baliknya jadi aku mau kasih petunjuk.'
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: Om pasti nyari minyak lampu buat Bakeneko ya? Sebenarnya itu minyak
      ikan yang ada di ruangan sebelumnya. Aku kasih kunci pintu lemarinya, om tinggal
      ambil aja.
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: Chopirako
    isiTeks: semoga membantu, sampai jumpa lagi....
    potretKarakter: {fileID: 5844234701645550739, guid: 811fd981218c08f4dbf28fa12bfdc612, type: 3}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: (Kamu mendapatkan Kunci Lemari Chopirako!)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
