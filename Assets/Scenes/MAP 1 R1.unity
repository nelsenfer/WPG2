--- !u!114 &1745848818
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1745848816}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 03ddb0e2fc517f94dbd5ea5b993d3175, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  potretTaku: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
  naskahMonolog:
  - namaKarakter: Taku
    isiTeks: "Hmmm... baru melihat luarnya pun firasatku dah beda dari rumah \u2013
      rumah sebelumnya.."
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: "(Taku masuk ke mansion itu untuk berniat merekam pengalaman rumah kosong
      seperti biasa. Namun, suatu ketika saat sedang berjalan tiba \u2013 tiba kameranya
      mati.)"
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: What the.... ini kenapa lagi kamera gk bisa nyala.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: (Taku teringat bahwa barang berharganya ia tinggalkan di mobil.)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: Sial HP ku dan batrei cadanganku ada di mobil.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
  - namaKarakter: 
    isiTeks: (Taku mulai kesal, akan tetapi ia berusaha untuk melanjutkan perjalanan.)
    potretKarakter: {fileID: 0}
    potretDiKiri: 0
  - namaKarakter: Taku
    isiTeks: Baiklah kita akan eksplorasi tempat ini. Tapi pertama kita cek pintu
      itu.
    potretKarakter: {fileID: 5569977257535576499, guid: 6401f72f80945344fbf4af380a5afc6c, type: 3}
    potretDiKiri: 0
